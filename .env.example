# Required — generation runs on Claude
ANTHROPIC_API_KEY=

# Optional — model override (default: claude-sonnet-5)
# UNIQ_MODEL=

# Optional — persistence (without it, proposals are in-memory only)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — require Authorization: Bearer <key> on the API + MCP
# UNIQ_API_KEY=

# Optional — public base URL used in hosted proposal links
# UNIQ_BASE_URL=https://uniq.team
